# App
APP_ENV=development
APP_SECRET_KEY=change-me-to-random-32-chars
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# Database (local Docker)
DATABASE_URL=postgresql+asyncpg://pbf_user:pbf_pass@localhost:5432/priyadarshini

# Connection pool (keep small behind a transaction-mode pooler like Supabase pgbouncer)
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=5
DB_POOL_TIMEOUT=30

# Supabase (production only) - fill these in your deployment platform's secret store.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_DB_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-1-REGION.pooler.supabase.com:6543/postgres

# Scraper
SCRAPER_SOURCE_URL=https://www.tickettogetlost.com/2026/06/14/ksrtc-women-free-bus-list-timings-priyadarshini-scheme-kerala/
SCRAPER_RATE_LIMIT_SECONDS=2
SCRAPER_USER_AGENT=PriyadarshiniBusFinder/1.0 (+https://priyadarshinibus.in/about)
SCRAPER_ALERT_EMAIL=your@email.com
# Abort the scrape write if parsed routes drop below this fraction of the last good run.
SCRAPER_MIN_ROUTE_RATIO=0.7

# OSM Geocoding
OSM_OVERPASS_URL=https://overpass-api.de/api/interpreter
OSM_NOMINATIM_URL=https://nominatim.openstreetmap.org/search
GEOCODING_ENABLED=true

# Feature Flags
ENABLE_ANALYTICS=false
MAX_NEARBY_RADIUS_METRES=2000
DEFAULT_NEARBY_RADIUS_METRES=1000
